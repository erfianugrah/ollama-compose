# Gemma 4 31B Dense — multimodal (text + vision), tool calling, thinking
# ~19 GB model + 1.2 GB mmproj | 31B active params (dense)
# Best for: coding with image context, multimodal tasks, general agentic work
MODEL_REPO=ggml-org/gemma-4-31B-it-GGUF
MODEL_FILE=gemma-4-31B-it-Q4_K_M.gguf
MODEL_NAME=Gemma 4 31B Dense (local)
MMPROJ_FILE=mmproj-gemma-4-31B-it-f16.gguf
MMPROJ_URL=https://huggingface.co/ggml-org/gemma-4-31B-it-GGUF/resolve/main/mmproj-gemma-4-31B-it-f16.gguf
TEMPLATE_FILE=google-gemma-4-interleaved.jinja
TEMPLATE_URL=https://raw.githubusercontent.com/ggml-org/llama.cpp/master/models/templates/google-gemma-4-interleaved.jinja
REASONING=on
CONTEXT_SIZE=65536
TEMPERATURE=1.0
TOP_P=0.95
TOP_K=64
MIN_P=0.05
